generator client {
  provider = "prisma-client-js"
}

// Neon/Vercel Postgres datasource.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// Postgres supports enums natively.

enum Role {
  PARENT
  CHILD
  RELATIVE // added in migration add_grandparent_relatives_feed
}

enum Gender {
  BOY
  GIRL
}

enum Subject {
  MATH
  READING
  ENGLISH
  PE
}

enum ItemCategory {
  FURNITURE
  OUTFIT_HAIR
  OUTFIT_TOP
  OUTFIT_BOTTOM
  PET
}

// Identifies which grandparent NPC issued the task.
enum Grandparent {
  GRANDMA
  GRANDPA
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  // avatarUrl/avatarKey: optional Vercel Blob reference for parent profile photo.
  avatarUrl    String?
  avatarKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  children  Child[]
  relatives Relative[]
  feedPosts FeedPost[]
}

model Child {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
  displayName  String
  parentId     String
  parent       Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  coins     Int    @default(0)
  energy    Int    @default(100)
  homeLevel Int    @default(1)
  gender    Gender @default(BOY)
  grade     Int    @default(1) // School grade 1-7, set by parent at child creation.

  // avatarUrl/avatarKey: optional Vercel Blob reference for child avatar shown on parent dashboard.
  avatarUrl String?
  avatarKey String?

  // Quest progression flags (talk events, lobby-plays counter, initial-quest
  // completion stamp, etc.). Stored as JSON so we can extend the schema
  // without a new migration each time we add a quest type.
  questFlags Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress         SubjectProgress[]
  attempts         TaskAttempt[]
  peSessions       PESession[]
  inventory        InventoryItem[]
  rooms            Room[]
  appearance       CharacterAppearance?
  grandparentTasks GrandparentTaskCompletion[]
  feedPosts        FeedPost[]

  // Index reason: parentId is used in WHERE when a parent loads their children list.
  @@index([parentId])
}

model SubjectProgress {
  id              String  @id @default(cuid())
  childId         String
  subject         Subject
  level           Int     @default(1) // current unlocked level
  completedLevels Int     @default(0) // how many levels finished
  totalXp         Int     @default(0)
  child           Child   @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Unique reason: each child has exactly one progress record per subject.
  @@unique([childId, subject])
}

model TaskAttempt {
  id           String   @id @default(cuid())
  childId      String
  subject      Subject
  level        Int
  correctCount Int
  totalCount   Int
  passed       Boolean
  coinsEarned  Int      @default(0)
  energyEarned Int      @default(0)
  xpEarned     Int      @default(0)
  durationMs   Int      @default(0)
  createdAt    DateTime @default(now())
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Index reason: filtered by childId+subject ordered by createdAt in progress history queries.
  @@index([childId, subject, createdAt])
}

model PESession {
  id           String   @id @default(cuid())
  childId      String
  exerciseKey  String // key from PE catalog ('squats', 'jumps', ...)
  exerciseName String // snapshot of name in case catalog changes
  photo10sUrl  String? // full URL in Vercel Blob
  photo10sKey  String? // blob object key (for deletion)
  photo60sUrl  String?
  photo60sKey  String?
  completed    Boolean  @default(false)
  coinsEarned  Int      @default(0)
  energyEarned Int      @default(0)
  createdAt    DateTime @default(now())
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  // Index reason: parent dashboard loads PE sessions for a child ordered by date.
  @@index([childId, createdAt])
}

model Room {
  id       String  @id @default(cuid())
  childId  String
  index    Int // 0 = first room, 1 = second room
  unlocked Boolean @default(false)
  child    Child   @relation(fields: [childId], references: [id], onDelete: Cascade)

  placements RoomPlacement[]

  // Unique reason: each child has at most one Room record per room index slot.
  @@unique([childId, index])
}

model RoomPlacement {
  id       String        @id @default(cuid())
  roomId   String
  itemId   String // references InventoryItem
  x        Int // grid x-coordinate
  y        Int // grid y-coordinate
  rotation Int           @default(0)
  room     Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Unique reason: one inventory item can occupy only one placement slot.
  // Index reason: roomId is used in WHERE when loading all placements for a room.
  @@unique([itemId])
  @@index([roomId])
}

model InventoryItem {
  id         String       @id @default(cuid())
  childId    String
  catalogKey String // 'chair_red', 'lamp_classic', ...
  category   ItemCategory
  ownedAt    DateTime     @default(now())
  child      Child        @relation(fields: [childId], references: [id], onDelete: Cascade)

  placement RoomPlacement?

  // Index reason: childId+category used in WHERE when filtering inventory by type (furniture tab, outfits tab, etc.).
  @@index([childId, category])
}

model CharacterAppearance {
  id      String  @id @default(cuid())
  childId String  @unique
  hair    String  @default("hair_default")
  top     String  @default("top_default")
  bottom  String  @default("bottom_default")
  petKey  String? // set when a pet is purchased
  child   Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Grandparent tasks (Phase E)
// ---------------------------------------------------------------------------

// Records a completed grandparent task submission with photo proof.
// One record per (child, taskKey) — re-submission overwrites via upsert.
model GrandparentTaskCompletion {
  id           String      @id @default(cuid())
  childId      String
  grandparent  Grandparent
  taskKey      String
  taskName     String
  photoUrl     String
  photoKey     String
  coinsEarned  Int
  energyEarned Int
  createdAt    DateTime    @default(now())
  child        Child       @relation(fields: [childId], references: [id], onDelete: Cascade)

  // One submission per task per child (re-submission updates existing row via upsert).
  @@unique([childId, taskKey])
  // Index reason: parent dashboard groups by grandparent + child, ordered by createdAt.
  @@index([childId, grandparent, createdAt])
}

// ---------------------------------------------------------------------------
// Relatives (Phase E) — family members with read-only feed access
// ---------------------------------------------------------------------------

// A relative (e.g. grandparent account) created by a parent. Has RELATIVE role
// in JWT. Can log in, see feed, leave comments and likes, but cannot access
// child management pages (/parent/child/*).
model Relative {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  avatarKey    String?
  parentId     String
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  // Index reason: listRelatives queries by parentId; Relative.parentId used in WHERE
  // when parent manages their relatives list.
  @@index([parentId])
}

// ---------------------------------------------------------------------------
// Feed (Phase E) — activity stream visible to parents and relatives
// ---------------------------------------------------------------------------

// A feed post is created automatically when a child completes a PE session
// or a grandparent task, or (in future) other notable actions.
model FeedPost {
  id           String   @id @default(cuid())
  parentId     String
  childId      String
  kind         String // 'PE' | 'GRANDPARENT' | 'TASK'
  title        String
  photoUrl     String?
  photoKey     String?
  rewardCoins  Int      @default(0)
  rewardEnergy Int      @default(0)
  createdAt    DateTime @default(now())

  child    Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent   Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  comments FeedComment[]
  likes    FeedLike[]

  // Index reason: feed query — by parentId ordered by createdAt desc (primary feed query).
  @@index([parentId, createdAt])
  // Index reason: child-specific filter in feed (parent filtering by one child).
  @@index([childId, createdAt])
}

// FeedComment stores authorType + authorId without hard FK to Parent/Relative.
// This avoids a polymorphic FK problem and simplifies migrations — the caller
// resolves the author name via the authorName snapshot field.
model FeedComment {
  id         String   @id @default(cuid())
  postId     String
  authorType String // 'PARENT' | 'RELATIVE'
  authorId   String // Parent.id or Relative.id — resolved at query time, no FK
  authorName String // name snapshot at comment creation
  body       String
  createdAt  DateTime @default(now())

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Index reason: getPostDetail loads comments for a post ordered by createdAt.
  @@index([postId, createdAt])
  // Index reason: allows finding all comments by a given author (e.g. to scrub on delete).
  @@index([authorType, authorId])
}

// FeedLike uses the same authorType + authorId pattern as FeedComment.
// The unique constraint prevents double-liking.
model FeedLike {
  id         String   @id @default(cuid())
  postId     String
  authorType String // 'PARENT' | 'RELATIVE'
  authorId   String
  createdAt  DateTime @default(now())

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Unique reason: one like per (post, author) — enforces toggleLike semantics.
  @@unique([postId, authorType, authorId])
  // Index reason: count likes per post in feed list query.
  @@index([postId])
}

// ---------------------------------------------------------------------------
// Lobby / Multiplayer (Phase 7) — tile-stomp mini-game
// ---------------------------------------------------------------------------

model LobbyMatch {
  id          String    @id @default(cuid())
  status      String    @default("WAITING") // WAITING | ACTIVE | FINISHED
  startedAt   DateTime?
  endsAt      DateTime?
  lastSpawnAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  players LobbyPlayer[]
  tiles   LobbyTile[]

  // Index reason: lobby-page lookup is "find latest WAITING match" → status + createdAt.
  @@index([status, createdAt])
}

model LobbyPlayer {
  id          String   @id @default(cuid())
  matchId     String
  childId     String
  displayName String
  x           Float    @default(0)
  y           Float    @default(0)
  score       Int      @default(0)
  lastMoveAt  DateTime @default(now())
  joinedAt    DateTime @default(now())

  match LobbyMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Unique reason: a child can only be in one match at a time per LobbyMatch row.
  // Index reason: getMatchState fetches all players for a match.
  @@unique([matchId, childId])
  @@index([matchId])
}

model LobbyTile {
  id          String    @id @default(cuid())
  matchId     String
  x           Int
  y           Int
  stompedById String? // childId of player who claimed it (null = unclaimed)
  spawnedAt   DateTime  @default(now())
  stompedAt   DateTime?

  match LobbyMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Unique reason: at most one tile per (match, x, y) coordinate.
  // Index reason: getMatchState filters by matchId; movePlayer queries tile by (match,x,y).
  @@unique([matchId, x, y])
  @@index([matchId, stompedById])
}

// LobbyPresence — heartbeat-based "who is currently in the lobby world" table.
// Distinct from LobbyMatch/Player which model the coin-collection mini-game.
// Children upsert this row every ~300 ms while inside /play/lobby; presence
// queries return rows whose lastHeartbeatAt is recent (≤8 s ago).
//
// vx/vz are world-space velocity components (units/second) — clients use them
// to extrapolate the remote player's position between heartbeats so movement
// looks continuous instead of stair-stepped. yaw is the character's facing
// angle (radians, world Y-axis). isRunning / isJumping pick the right
// animation clip on remote clients.
model LobbyPresence {
  childId         String   @id
  displayName     String
  gender          Gender   @default(BOY)
  x               Float    @default(0)
  z               Float    @default(0)
  yaw             Float    @default(0)
  vx              Float    @default(0)
  vz              Float    @default(0)
  isRunning       Boolean  @default(false)
  isJumping       Boolean  @default(false)
  lastHeartbeatAt DateTime @default(now())

  // Index reason: getActivePresence orders/filters by lastHeartbeatAt.
  @@index([lastHeartbeatAt])
}
