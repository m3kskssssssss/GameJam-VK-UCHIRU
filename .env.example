# Postgres connection. Local dev: any Postgres you have running.
# Production: Vercel Postgres injected by the integration.
DATABASE_URL="postgresql://kidquest:kidquest@localhost:5432/kidquest"

# NextAuth (Auth.js v5). Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL of the running app. Locally, http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob token for PE photos. Provided by the integration in prod.
# For local dev, leave empty unless testing PE upload locally.
BLOB_READ_WRITE_TOKEN=""
